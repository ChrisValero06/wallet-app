# --- Base de datos ---
# SQLite (desarrollo):
DATABASE_URL=sqlite:///./wallet.db
# PostgreSQL (producción):
# DATABASE_URL=postgresql://user:password@localhost:5432/wallet_db

# --- JWT ---
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-segura-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Cifrado de datos sensibles ---
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=tu-clave-fernet-de-32-bytes-en-base64-aqui

# --- CORS ---
FRONTEND_URL=http://localhost:5173
# Múltiples orígenes separados por coma (para producción agregar URL de Vercel)
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app
